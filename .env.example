# ── Supabase (plataforma interna /app) ──────────────────────────────
# Crie um projeto em https://supabase.com e copie de Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Allowlist da área interna ───────────────────────────────────────
# E-mails autorizados a acessar /app, separados por vírgula.
# Só estes conseguem entrar, mesmo com conta criada no Supabase.
INTERNAL_ALLOWED_EMAILS=fabricio@trevocode.com,yuri@trevocode.com
